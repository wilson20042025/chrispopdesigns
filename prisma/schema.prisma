generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Portfolio {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  category    String
  year        String
  location    String
  client      String
  description String   @db.Text
  heroImage   String
  details     Json     // Array of {label, value}
  gallery     String[] // Array of image URLs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("portfolio")
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  name     String?

  @@map("users")
}
